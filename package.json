{
  "name": "penny-pal-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram expense logging bot (TypeScript rewrite)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepare": "husky",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "verify": "npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "telegraf": "^4.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^25.7.0",
    "@types/node-fetch": "^2.6.13",
    "@types/safe-compare": "^1.1.2",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
