# Telegram bot token from BotFather
TELEGRAM_TOKEN=your-telegram-token

# Notion integration token
NOTION_TOKEN=your-notion-token

# Comma-separated Telegram user IDs allowed to use this bot
EXPENSE_BOT_ALLOWED_USER_IDS=123456789

# Fallback Notion database ID when no user-specific mapping is found
EXPENSE_BOT_DEFAULT_DB_ID=your-default-notion-db-id

# JSON map: Telegram user ID (string key) -> Notion DB ID
# Example: {"123456789":"aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"}
EXPENSE_BOT_USER_DB_MAP_JSON={}

# JSON map: Notion DB ID -> display label in messages
# Example: {"aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee":"Personal"}
EXPENSE_BOT_DB_LABELS_JSON={}

# Optional overrides
EXPENSE_BOT_PROCESS_TIMEOUT=300
EXPENSE_BOT_HERMES_TIMEOUT=240
